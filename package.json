{
  "name": "@josetra/wacon",
  "version": "0.4.0",
  "description": "WhatsApp AI CLI + MCP server — lets AI agents and humans manage WhatsApp with per-contact style memory, hybrid local RAG and episodic memory",
  "type": "module",
  "license": "MIT",
  "author": "JOSETRA44",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JOSETRA44/wacon-mcp.git"
  },
  "homepage": "https://github.com/JOSETRA44/wacon-mcp#readme",
  "bugs": {
    "url": "https://github.com/JOSETRA44/wacon-mcp/issues"
  },
  "keywords": [
    "whatsapp",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "baileys",
    "cli",
    "rag",
    "memory",
    "claude"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "wacon": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "skills",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "tsup",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.3",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
